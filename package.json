{
  "name": "qr-hover-link",
  "version": "1.0.1",
  "type": "module",
  "description": "A React component that overlays a clickable link on a QR code image when hovered — no phone needed.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "keywords": [
    "qr",
    "qr-code",
    "hover",
    "link",
    "react",
    "component",
    "npm-package"
  ],
  "author": "Arjun Gautam <contact@gautamarjun.com.np>",
  "repository": {
    "type": "git",
    "url": "https://github.com/opentechcommunity/qr-hover-link.git"
  },
  "homepage": "https://opentechcommunity.github.io/qr-hover-demo/",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "rollup": "^3.0.0",
    "rollup-plugin-dts": "^5.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0"
  }
